{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|NotebookEdit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/twt-scope-guard.js\""
          }
        ]
      },
      {
        "matcher": "Task|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/twt-debug-log.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/twt-debug-log.js\""
          }
        ]
      }
    ]
  }
}
